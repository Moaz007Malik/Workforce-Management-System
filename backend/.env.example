# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/workforce_management?retryWrites=true&w=majority

# Frontend URL(s) for CORS — comma-separated (REQUIRED on Vercel backend)
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-wms-app.vercel.app
# Multiple (production + preview):
# FRONTEND_URL=https://your-wms-app.vercel.app,https://your-wms-app-git-main.vercel.app

# Local dev port (Vercel sets PORT automatically)
PORT=3001

# Set to true on Windows if mongodb+srv DNS fails locally
FORCE_PUBLIC_DNS=false

# Set by Vercel automatically in production
# VERCEL=1
# NODE_ENV=production

# SMTP (optional — dashboard PDF email). Without these, export still works; email runs in demo mode.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Workforce Management System <your-email@gmail.com>"

# Auth (required in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Groq — powers the in-app assistant chatbot
# Get a key at https://console.groq.com/keys (starts with gsk_)
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# Demo data seeding is disabled by default. Do not set this until you intentionally want to load sample data.
# ALLOW_SEED=true
